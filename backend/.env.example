# ---- core ----
DATABASE_URL=sqlite:///./tracenet.db
JWT_SECRET=change_this_demo_secret
JWT_EXPIRE_MINUTES=120
DEMO_MFA_CODE=123456
GITHUB_API_BASE=https://api.github.com
CORS_ORIGINS=http://localhost:5173


# ---- Apify public OSINT connectors ----
# Get token from Apify Console -> Settings -> API & Integrations.
# Keep the cost caps low for hackathon runs. TRACE_APIFY_ONLY_MODE=true means
# the graph uses Apify connectors only, so results do not look like local/demo fallback.
APIFY_TOKEN=
TRACE_APIFY_ONLY_MODE=true
ENABLE_APIFY_MAIGRET=true
ENABLE_APIFY_PUBLIC_SEARCH=true
ENABLE_APIFY_WEB_SCRAPER=true
ENABLE_APIFY_USERNAME_SEARCH=true
ENABLE_APIFY_IP_DOMAIN_SEARCH=true
APIFY_MAIGRET_ACTOR_ID=ntriqpro/maigret-actor
APIFY_PUBLIC_SEARCH_ACTOR_ID=apify/google-search-scraper
APIFY_WEB_SCRAPER_ACTOR_ID=apify/web-scraper
APIFY_MAIGRET_TOP_SITES=100
APIFY_MAIGRET_SITE_TIMEOUT=8
APIFY_MAIGRET_NO_RECURSION=true
APIFY_MAIGRET_MAX_ITEMS=40
APIFY_SEARCH_MAX_PAGES=1
APIFY_SEARCH_MAX_RESULTS=20
APIFY_SEARCH_RESULTS_PER_PAGE=10
APIFY_FOLLOW_SEARCH_RESULT_PAGES=true
APIFY_FOLLOW_SEARCH_RESULT_LIMIT=2
APIFY_WEB_SCRAPER_MAX_PAGES=3
APIFY_WEB_SCRAPER_MAX_ITEMS=25
ENABLE_EMAIL_LOCALPART_USERNAME_DISCOVERY=true
APIFY_SEARCH_COUNTRY_CODE=in
APIFY_SEARCH_LANGUAGE_CODE=en
APIFY_ACTOR_TIMEOUT_SECONDS=120
APIFY_MAX_TOTAL_CHARGE_USD=0.50

# ---- OSINT connectors ----
# TRACE_APIFY_ONLY_MODE=true disables keyless GitHub/Gravatar during analysis.
# Set TRACE_APIFY_ONLY_MODE=false to mix Apify + keyless public connectors.
ENABLE_GRAVATAR=true

# Live public username existence check (Sherlock-lite). OFF by default because
# it queries live sites for a possibly-real username. Enable ONLY under lawful
# authority for real investigations.
ENABLE_LIVE_USERNAME_CHECK=false

# Private account-enumeration/login/contact-sync providers are not wired into this build.

# ---- MOSINT email OSINT connector ----
# OFF by default. Enable only for authorized/consent-based tests.
ENABLE_MOSINT=false
MOSINT_BINARY=mosint
MOSINT_CONFIG_PATH=.mosint.yaml
MOSINT_TIMEOUT_SECONDS=90
MOSINT_STORE_RESULTS=true

# Expanded Apify scraping actors
ENABLE_APIFY_INSTAGRAM=true
ENABLE_APIFY_TIKTOK=true
ENABLE_APIFY_TWITTER=true
ENABLE_APIFY_LINKEDIN=true
ENABLE_APIFY_REDDIT=true
ENABLE_APIFY_EMAIL_VERIFY=true
ENABLE_APIFY_DOMAIN_WHOIS=true
