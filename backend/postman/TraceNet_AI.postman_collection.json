{
  "info": {
    "name": "TraceNet AI API",
    "description": "Agentic SOCMINT case-management API. Public-data-only investigative leads. Human review required.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.code === 200);",
                  "var data = pm.response.json();",
                  "pm.environment.set('pending_token', data.pending_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/verify-mfa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.code === 200);",
                  "var data = pm.response.json();",
                  "pm.environment.set('access_token', data.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/auth/verify-mfa",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pending_token\": \"{{pending_token}}\",\n  \"code\": \"{{mfa_code}}\"\n}"
            }
          }
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Cases",
      "item": [
        {
          "name": "POST /cases (create)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.code === 200);",
                  "var data = pm.response.json();",
                  "pm.environment.set('case_id', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/cases",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"UPI Fraud Ring Investigation\",\n  \"jurisdiction\": \"Maharashtra Cybercrime Cell\",\n  \"priority\": \"high\",\n  \"legal_authority_ref\": \"FIR 2026/0519\",\n  \"lawful_purpose\": \"To identify, collect, and analyze publicly available information and relevant digital data to determine potential connections to activity that may involve fraud or identity misuse in support of a lawful investigation.\"\n}"
            }
          }
        },
        {
          "name": "GET /cases (list)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/cases",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "GET /cases/:id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/cases/{{case_id}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "POST /cases/:id/launch",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/cases/{{case_id}}/launch",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        }
      ]
    },
