    {
      "name": "Evidence",
      "item": [
        {
          "name": "GET /cases/:id/evidence",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "if (Array.isArray(data) && data.length > 0) pm.environment.set('evidence_id', data[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/cases/{{case_id}}/evidence",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "POST /cases/:id/evidence/upload (multipart file)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/cases/{{case_id}}/evidence/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            }
          }
        },
        {
          "name": "GET /cases/:id/evidence/:evidence_id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/cases/{{case_id}}/evidence/{{evidence_id}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "PATCH /cases/:id/evidence/:evidence_id (verify/reject/exclude)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/cases/{{case_id}}/evidence/{{evidence_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verification_status\": \"verified\",\n  \"note\": \"Confirmed via reviewer cross-check\"\n}"
            }
          }
        }
      ]
    },
